# Copy to .env and edit as needed.

# Directory for ChromaDB persistence + wiki cache.
# SQLite lives at $FONT_MCP_DATA_DIR/chroma/chroma.sqlite3
# Default if unset: <repo>/data
FONT_MCP_DATA_DIR=~/.font-mcp/

# Atlassian credentials for scripts/fetch_confluence.py
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_EMAIL=your-email@sandoll.co.kr
ATLASSIAN_TOKEN=your-api-token